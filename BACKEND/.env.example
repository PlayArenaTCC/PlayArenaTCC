PORT=3333
FRONTEND_URL=http://localhost:5173

# Cole aqui a connection string do Neon.
# Exemplo:
# DATABASE_URL=postgresql://usuario:senha@ep-exemplo.us-east-2.aws.neon.tech/playarena?sslmode=verify-full
DATABASE_URL=

# Troque por uma chave forte antes de publicar.
JWT_SECRET=troque_esta_chave

# E-mail de verificacao de cadastro.
# Use "local" em desenvolvimento: o codigo aparece no terminal do backend.
# Use "gmail" para enviar por Gmail SMTP com senha de app.
# Use "resend" para enviar o codigo por e-mail real via Resend.
EMAIL_PROVIDER=local
EMAIL_CODE_LENGTH=6
EMAIL_CODE_EXPIRATION_MINUTES=10
EMAIL_MAX_VERIFICATION_ATTEMPTS=5
EMAIL_RESEND_COOLDOWN_SECONDS=60
EMAIL_MAX_RESENDS=3

# Gmail SMTP.
# Ative a verificacao em duas etapas na conta Google e gere uma senha de app.
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM=PlayArena <seuemail@gmail.com>

# Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=PlayArena <onboarding@resend.dev>
# Opcional: sobrescreva se o endpoint da Resend mudar.
# RESEND_EMAIL_ENDPOINT=https://api.resend.com/emails
